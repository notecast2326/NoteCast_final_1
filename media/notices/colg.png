,\"5761:static/chunks/5761-7473846eb62dec99.js\",\"9160:static/chunks/9160-b14ce7a0f40092ff.js\",\"7062:static/chunks/7062-c0f763f1cff4bc8c.js\",\"5290:static/chunks/5290-86a15ece84b7717b.js\",\"4312:static/chunks/4312-36eada3ad3f104eb.js\",\"9626:static/chunks/9626-c044e72082d59d88.js\",\"7637:static/chunks/7637-0632fb63535840aa.js\",\"1325:static/chunks/1325-676e5ee437748034.js\",\"6000:static/chunks/app/(frontend)/(index)/page-4ca369d41042f9e9.js\"],\"name\":\"\",\"async\":false}\n"])</script><script>self.__next_f.push([1,"16:I{\"id\":96964,\"chunks\":[\"6990:static/chunks/13b76428-8906edfbf871694f.js\",\"1176:static/chunks/1176-8408177ae5ea3468.js\",\"5761:static/chunks/5761-7473846eb62dec99.js\",\"9160:static/chunks/9160-b14ce7a0f40092ff.js\",\"7062:static/chunks/7062-c0f763f1cff4bc8c.js\",\"5290:static/chunks/5290-86a15ece84b7717b.js\",\"4312:static/chunks/4312-36eada3ad3f104eb.js\",\"9626:static/chunks/9626-c044e72082d59d88.js\",\"7637:static/chunks/7637-0632fb63535840aa.js\",\"1325:static/chunks/1325-676e5ee437748034.js\",\"6000:static/chunks/app/(frontend)/(index)/page-4ca369d41042f9e9.js\"],\"name\":\"Image\",\"async\":false}\n"])</script><script>self.__next_f.push([1,"17:I{\"id\":13386,\"chunks\":[\"6990:static/chunks/13b76428-8906edfbf871694f.js\",\"1176:static/chunks/1176-8408177ae5ea3468.js\",\"5761:static/chunks/5761-7473846eb62dec99.js\",\"9160:static/chunks/9160-b14ce7a0f40092ff.js\",\"7062:static/chunks/7062-c0f763f1cff4bc8c.js\",\"5290:static/chunks/5290-86a15ece84b7717b.js\",\"4312:static/chunks/4312-36eada3ad3f104eb.js\",\"9626:static/chunks/9626-c044e72082d59d88.js\",\"7637:static/chunks/7637-0632fb63535840aa.js\",\"1325:static/chunks/1325-676e5ee437748034.js\",\"6000:static/chunks/app/(frontend)/(index)/page-4ca369d41042f9e9.js\"],\"name\":\"\",\"async\":false}\n"])</script><script>self.__next_f.push([1,"1b:I{\"id\":41257,\"chunks\":[\"6990:static/chunks/13b76428-8906edfbf871694f.js\",\"1176:static/chunks/1176-8408177ae5ea3468.js\",\"5761:static/chunks/5761-7473846eb62dec99.js\",\"9160:static/chunks/9160-b14ce7a0f40092ff.js\",\"7062:static/chunks/7062-c0f763f1cff4bc8c.js\",\"5290:static/chunks/5290-86a15ece84b7717b.js\",\"4312:static/chunks/4312-36eada3ad3f104eb.js\",\"9626:static/chunks/9626-c044e72082d59d88.js\",\"7637:static/chunks/7637-0632fb63535840aa.js\",\"1325:static/chunks/1325-676e5ee437748034.js\",\"6000:static/chunks/app/(frontend)/(index)/page-4ca369d41042f9e9.js\"],\"name\":\"\",\"async\":false}\n"])</script><script>self.__next_f.push([1,"10:T45b,"])</script><script>self.__next_f.push([1,"\u003cp\u003eAt Sir Syed Institute for Technical Studies, we believe in fostering an environment of academic excellence, personal growth, and community engagement. Whether you're a prospective student, a current student, an alumni member, or simply interested in learning more about us, we're thrilled to have you here. Our institution is dedicated to providing top-notch education, equipping our students with the knowledge, skills, and experiences they need to thrive in a rapidly evolving world. With a diverse range of programs, state-of-the-art facilities, and passionate faculty members, we're committed to empowering our students to reach their full potential. As you explore our website, we encourage you to discover the countless opportunities available to you at Sir Syed Institute. From academic programs to extracurricular activities, student support services to campus events, there's something here for everyone.\u003c/p\u003e\n\u003cp\u003eThank you for choosing Sir Syed Institute. We're excited to embark on this journey with you and to help you achieve your goals. Together, let's make your college experience unforgettable!\u003c/p\u003e"])</script><script>self.__next_f.push([1,"11:Td3d,"])</script><script>self.__next_f.push([1,"\u003cp class=\"MsoNormal\" style=\"text-align: justify;\"\u003e\u003cspan lang=\"EN-US\"\u003eI am happy to share with you the remarkable achievements and ongoing contributions of Sir Syed Institute for Technical Studies (SSITS), Taliparamba. Established in 2002, as a self-financing college, affiliated with Kannur University, has proudly upheld the legacy of the great reformer Sir Syed Ahmed Khan, operating under the esteemed guidance of CDMEA.\u003c/span\u003e\u003cspan lang=\"EN-US\"\u003eAt Sir Syed Institute, we provide a wide range of academic programs, including 13 undergraduate and 4 postgraduate courses spanning Arts, Science and Commerce streams. Our institute, with a student body of 1600, takes pride in a committed faculty, featuring Ph.D. and M.Phil. holders, dedicated to fostering a high-quality learning environment. Through sincere and systematic practices, our students have excelled in University examinations, securing top ranks, and have showcased their talents by attaining notable positions in Kalolsavam and sports events hosted by the University. The unwavering support of the Management, PTA, and Alumni serves as the backbone for all our activities.\u003c/span\u003e\u003c/p\u003e\n\u003cp class=\"MsoNormal\" style=\"text-align: justify;\"\u003e\u003cspan lang=\"EN-US\"\u003eOur college has always been at the forefront of higher education ,and we take pride in our students\u0026rsquo; outstanding performance.As always this year too witnessed several University Rank Holders,a testament to our commitment to academic excellence.Our PG students have successfully carried out impactful research projects within the institution, further strengthening our reputation for fostering innovation and inquiry.To cater to the evolving educational landscape , we have introduced new Postgraduate and undergraduate courses, ensuring our students to have access to a diverse and dynamic curriculum.Our state of the art laboratories provide exceptional facilities allowing students to gain hands on experience and enhance their technical expertise.\u003c/span\u003e\u003c/p\u003e\n\u003cp class=\"MsoNormal\" style=\"text-align: justify;\"\u003e\u003cspan lang=\"EN-US\"\u003eBeyond academics, we strongly believe in holistic student development. Our institution regularly organizes numerous extracurricular programmes to foster their performances in corresponding fields.Tharang, College Kalotsavam organized prior to University Kalotsavam was one of its kind.This was aimed at preparing them for the upcoming University Kalotsavam.\u003c/span\u003e\u003cspan lang=\"EN-US\"\u003eIn our continuous efforts to guide students toward successful careers, we conduct motivational classes,career guidance sessions and skill development programmes.Our Skill Development centre serves as a hub for enhancing students\u0026rsquo; abilities, collaborating with esteemed institutions like ASAP, IHRD and K-DISC to offer skill based training development opportunities.\u003c/span\u003e\u003c/p\u003e\n\u003cp class=\"MsoNormal\" style=\"text-align: justify;\"\u003e\u003cspan lang=\"EN-US\"\u003eOur journey towards excellence is driven by our dedicated faculty , enthulsiastic students and a vibrant campus culture.We remain committed to providing a nurturing environment where every student can achieve full potential.\u003c/span\u003e\u003c/p\u003e\n\u003cp dir=\"ltr\" style=\"text-align: left;\"\u003eWarm regards,\u003c/p\u003e\n\u003ch4 dir=\"ltr\" style=\"text-align: left;\"\u003eDr. SIRAJ M V P\u003c/h4\u003e\n\u003cp dir=\"ltr\" style=\"text-align: left;\"\u003ePrincipal\u003c/p\u003e\n\u003cp dir=\"ltr\" style=\"text-align: left;\"\u003e\u0026nbsp;\u003c/p\u003e\n\u003cp style=\"text-align: justify;\"\u003e\u0026nbsp;\u003c/p\u003e"])</script><script>self.__next_f.push([1,"18:T5f9,"])</script><script>self.__next_f.push([1,"\u003cp\u003eI am Swathi Pavithran, currently pursuing my graduate studies at Cincinnati Children's Hospital Medical Center (CCHMC) in Ohio, USA. My academic journey began at Sir Syed Institute For Technical Studies, where I earned my Bachelor\u0026rsquo;s degree in Biotechnology. It was during my time there that my passion for research truly blossomed. The institute provided me with invaluable hands-on experience in campus labs, allowing me to explore the practical aspects of biotechnology. This exposure sparked my curiosity and set the foundation for my current research endeavors. I owe much of my growth to the immersive and encouraging environment fostered by the faculty, who were instrumental in guiding me through my initial stages of learning. In particular, I would like to extend my deepest gratitude to Dr. Siraj M V, who has been a constant source of inspiration and support throughout my academic career. His mentorship and dedication to his students created an environment where we were encouraged to challenge ourselves and pursue our aspirations. Today, as I continue my academic journey in a highly regarded research center, I carry with me the lessons learned and the support received from Sir Syed Institute. The experience has been fundamental in shaping my career path, and I am proud to be an alumnus of such a nurturing institution. My heartfelt best wishes to Sir Syed Institute, its remarkable faculty, and the future students. May the institution continue to inspire, nurture, and lead many more to success.\u003c/p\u003e"])</script><script>self.__next_f.push([1,"19:T5a7,"])</script><script>self.__next_f.push([1,"\u003cp\u003eI am Munavira Mukkoth, and I completed my M.Sc in Biotechnology from Sir Syed Institute during the 2020-2022 academic year. As an alumnus of the M.Sc Biotechnology program at Sir Syed Institute, I can confidently say that my time there was pivotal in shaping my educational and professional journey, even though I was a chemistry graduate. The comprehensive curriculum, hands-on lab experience, and expert faculty guidance laid a strong foundation for my current studies in MRes Applied Sciences at UWE Bristol, where I am now focusing on breast cancer research. The strongest support I got from the faculties especially Siraj sir, Thasneem ma'am, Shabna Ma'am, and Neema ma'am was highly appreciable to pursue my career in research. They cleared my every doubt related to both theoretically and practically. Especially Thasneem ma'am, she was so helpful while choosing the research topic for my MRes. The exposure to cutting-edge biotechnological techniques and the institute's emphasis on research equipped me with the critical thinking and problem-solving skills required in my field. The supportive learning environment at Sir Syed Institute not only deepened my understanding of core biotechnology concepts but also encouraged me to pursue my passion for cancer research. I am deeply grateful for the opportunities and mentorship I received, which continue to guide me as I contribute to advancing scientific research in breast cancer.\u003c/p\u003e"])</script><script>self.__next_f.push([1,"1a:T601,"])</script><script>self.__next_f.push([1,"\u003cp\u003eI Anjana Vijayan currently I am a research scholar at CSIR-CCMB Hyderabad. I am truly grateful for the invaluable support I received during my time at SSITS The faculty, especially the Head of Biotechnology department Dr. Siraj M. V. P. He played a crucial role in my academic and personal growth. The faculties dedication to student success and willingness to provide guidance made a significant difference in my experience. The encouragement and mentorship I received helped me overcome challenges and pursue my goals with confidence. I am proud to be an alumnus of Department of Biotechnology, Sir Syed Institute and will always cherish the knowledge and skills I gained, thanks to the exceptional faculty. My experience at SSITS was pivotal in my academic journey, particularly during my transition from physical science to life science. I faced many challenges, but the support I received from the faculty, especially the Head of Department, was instrumental. He guided me in preparing for CSIR UGC NET EXAM which ultimately led to my research scholar position at a prestigious institute CCMB HYDERABAD. I am deeply thankful for his mentorship and encouragement, which helped me find my path and succeed. I will always be grateful for the nurturing environment at SSITS and the invaluable guidance I received. I hope that SSITS continues to provide this level of support to more students, helping them achieve their goals and realize their potential. I will always cherish my time here and the invaluable guidance I received.\u003c/p\u003e"])</script><script>self.__next_f.push([1,"c:[[\"$\",\"$Ld\",null,{\"topStatus\":true}],[\"$\",\"section\",null,{\"className\":\"w-100 h-100\",\"children\":[\"$\",\"$Le\",null,{\"data\":[{\"_id\":\"657480e47a053194a6549f54\",\"menuName\":\"Slider\",\"title\":\"Slider\",\"order\":null,\"images\":[{\"fileCaption\":\"\\\"Education is the most powerful weapon which you can use to change the world.\\\" – Nelson Mandela\",\"filePath\":\"uploads/Sir Syed Institute Photo-2025-05-10-16-17-30.186.jpeg\"},{\"fileCaption\":\"\\\"The future belongs to those who believe in the beauty of their dreams.\\\" – Eleanor Roosevelt\",\"filePath\":\"uploads/lib 1-2024-03-31-14-01-12.679.png\"},{\"fileCaption\":\"\\\"An investment in knowledge pays the best interest.\\\" – Benjamin Franklin\",\"filePath\":\"uploads/WhatsApp Image 2025-04-09 at 3.00.13 PM-2025-05-10-16-18-23.559.jpeg\"},{\"fileCaption\":\"\\\"The roots of education are bitter, but the fruit is sweet.\\\" – Aristotle\",\"filePath\":\"uploads/WhatsApp Image 2025-04-30 at 5.27.24 PM-2025-05-10-16-19-29.635.jpeg\"},{\"fileCaption\":\"\\\"The beautiful thing about learning is that no one can take it away from you.\\\" \",\"filePath\":\"uploads/micro lab-2024-08-06-06-50-50.238.png\"},{\"fileCaption\":\"SSITS\",\"filePath\":\"uploads/WhatsApp Image 2025-02-25 at 8.40.10 PM-2025-05-10-16-21-39.701.jpeg\"},{\"fileCaption\":\"SSITS\",\"filePath\":\"uploads/WhatsApp Image 2025-05-09 at 8.48.44 PM-2025-05-10-16-23-19.017.jpeg\"},{\"fileCaption\":\"ssits\",\"filePath\":\"uploads/WhatsApp Image 2025-04-29 at 4.07.28 PM-2025-05-10-16-26-39.219.jpeg\"},{\"fileCaption\":\"xxx\",\"filePath\":\"uploads\\\\Screenshot 2025-09-09 215653-2025-09-25-05-48-57.854.png\"}],\"files\":[],\"links\":[],\"url\":\"\"}],\"notification\":[{\"_id\":\"693bb866c499eda417616dce\",\"menuName\":\"General\",\"title\":\"Time Table for FIRST semester FYUGP Examination ,November 2025\",\"url\":\"https://admission.kannuruniversity.ac.in/examination/examnew/uploads/timetable/1952.pdf\",\"images\":[],\"files\":[],\"links\":[]},{\"_id\":\"693bb8ffc499eda417616e36\",\"menuName\":\"General\",\"title\":\"TIMETABLE FOR FIRST SEMESTER M. A./ M. Sc./ M. Com./ M. S. W./MTTM DEGREE (C.B.C.S.S/ C. B.C. S.S-.O.B.E - 2023 to 2025 ADMISSIONSREGULAR/SUPPLEMENTARY/IMPROVEMENT ) EXAMINATIONS, OCTOBER 2025\",\"url\":\"https://admission.kannuruniversity.ac.in/examination/examnew/uploads/timetable/1940.pdf\",\"images\":[],\"files\":[],\"links\":[]}]}]}],[\"$\",\"section\",null,{\"className\":\"bg-color-white pt-md-0 pb-md-0\",\"children\":[\"$\",\"$Lf\",null,{\"data\":[{\"_id\":\"657481037a053194a6549f5a\",\"menuName\":\"Welcome Message\",\"title\":\"WELCOME MESSAGE\",\"excerpt\":\"At Sir Syed Institute for Technical Studies, we believe in fostering an environment of academic excellence, personal growth, and community engagement. Whether you're a prospective student, a current student, an alumni ...\",\"url\":\"\",\"images\":[{\"fileCaption\":\"SIR SYED INSTITUTE\",\"filePath\":\"uploads/WhatsApp Image 2023-07-15 at 16.36.55-2025-04-30-09-08-06.335.jpeg\"}],\"files\":[],\"links\":[],\"description\":\"$10\"}],\"news\":[{\"_id\":\"693ba7c1c499eda41761654c\",\"menuName\":\"News\",\"title\":\"CAMPUS CLEANING DRIVE\",\"excerpt\":\"On 15 November 2025,Campus cleaning drive was organized by the cleanliness and beautification committee in association with NCC and NSS.The program was inaugurated by\u0026nbsp; the principal Dr.Siraj\u0026nbsp; M V P .The Drive ...\",\"location\":\"SSITS\",\"date\":\"2025-11-15T04:00:00.000Z