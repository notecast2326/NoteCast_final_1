irection\":\"left\",\"children\":[[\"$\",\"li\",\"0\",{\"children\":[\"$\",\"$L13\",null,{\"href\":\"#\",\"className\":\"ms-5\",\"children\":[\"$\",\"$L16\",null,{\"src\":\"https://sirsyedinstitute.ac.in/uploads/KAS Mentor-2024-08-02-08-29-42.644.jpeg\",\"width\":\"160\",\"height\":\"80\",\"alt\":\"KAS Mentor\"}]}]}],[\"$\",\"li\",\"1\",{\"children\":[\"$\",\"$L13\",null,{\"href\":\"#\",\"className\":\"ms-5\",\"children\":[\"$\",\"$L16\",null,{\"src\":\"https://sirsyedinstitute.ac.in/uploads/ASAP-2024-08-06-08-29-36.456.jpeg\",\"width\":\"160\",\"height\":\"80\",\"alt\":\"ASAP\"}]}]}],[\"$\",\"li\",\"2\",{\"children\":[\"$\",\"$L13\",null,{\"href\":\"#\",\"className\":\"ms-5\",\"children\":[\"$\",\"$L16\",null,{\"src\":\"https://sirsyedinstitute.ac.in/uploads/International skill Development Corperation-2024-08-06-08-30-24.995.jpeg\",\"width\":\"160\",\"height\":\"80\",\"alt\":\"International Skill Development Corporation\"}]}]}],[\"$\",\"li\",\"3\",{\"children\":[\"$\",\"$L13\",null,{\"href\":\"#\",\"className\":\"ms-5\",\"children\":[\"$\",\"$L16\",null,{\"src\":\"https://sirsyedinstitute.ac.in/uploads/IIM-2024-08-06-08-30-45.071.jpeg\",\"width\":\"160\",\"height\":\"80\",\"alt\":\"IIM Trichy\"}]}]}],[\"$\",\"li\",\"4\",{\"children\":[\"$\",\"$L13\",null,{\"href\":\"#\",\"className\":\"ms-5\",\"children\":[\"$\",\"$L16\",null,{\"src\":\"https://sirsyedinstitute.ac.in/uploads/Kerala Knowledge Economy Mission-2024-08-06-08-31-18.280.jpeg\",\"width\":\"160\",\"height\":\"80\",\"alt\":\"Kerala Knowledge Economy Mission\"}]}]}],[\"$\",\"li\",\"5\",{\"children\":[\"$\",\"$L13\",null,{\"href\":\"#\",\"className\":\"ms-5\",\"children\":[\"$\",\"$L16\",null,{\"src\":\"https://sirsyedinstitute.ac.in/uploads/Sharjah Research Technology and Innovation Park-2024-08-06-08-31-51.674.jpeg\",\"width\":\"160\",\"height\":\"80\",\"alt\":\"Sharjah Research Technology and Innovation Park\"}]}]}]]}]}]}]}]]}]}],[\"$\",\"div\",null,{\"className\":\"col-lg-3\"}]]}]}]]}]}]}]}],[\"$\",\"section\",null,{\"className\":\"bg-white\",\"children\":[\"$\",\"div\",null,{\"className\":\"wrapper-space\",\"children\":[\"$\",\"div\",null,{\"className\":\"container-fluid ptb--60\",\"children\":[\"$\",\"div\",null,{\"className\":\"row\",\"children\":[[\"$\",\"div\",null,{\"className\":\"col-lg-9 mb--60\",\"children\":[\"$\",\"div\",null,{\"className\":\"section-title\",\"children\":[[\"$\",\"h2\",null,{\"className\":\"title text-uppercase\",\"children\":\"Testimonial\"}],[\"$\",\"p\",null,{\"className\":\"m-0 mb-5\",\"children\":\"concise statement from a student or alumnus sharing their positive experience at the institution, focusing on academic quality, campus life, or personal growth\"}],[\"$\",\"$L17\",null,{\"data\":[{\"_id\":\"681f8763646ea90521bbf465\",\"menuName\":\"Testimonials\",\"title\":\"Sri. RAMACHANDRAN KADANNAPPALLI\",\"shortDesc\":\"Minister for Registration, Museum, Archaeology and Archives, Govt. of Kerala\",\"excerpt\":\"Sir Syed Institute for Technical Studies under the management of Cannanore District Muslim Educational Association is well known for its dedication. I am very happy to know that the P.G Department of Biotechnology is ...\",\"url\":\"\",\"order\":1,\"images\":[{\"fileCaption\":\"Sri. Ramachandran Kadannappalli\",\"filePath\":\"uploads/IMG_6710-1-683x1024-2025-05-10-17-07-10.175.jpg\"}],\"files\":[],\"links\":[],\"description\":\"\u003cp\u003eSir Syed Institute for Technical Studies under the management of Cannanore District Muslim Educational Association is well known for its dedication. I am very happy to know that the P.G Department of Biotechnology is celebrating its 20th Anniversary. Biotechnology has a prominent role to play in our day to day life. It is also noted that a Newsletter is being published to bring out the achivements of the two decades of the developmental activities of the department\u003c/p\u003e\\n\u003cp\u003eKerala Government is providing all facilities for promoting higher education. I extend my sincere wishes to dear students and teachers and management and PTA. May your hardwork and sincerity achieve a prestigious position in the educational arena\u003c/p\u003e\\n\u003cp\u003eWith warm Regards\u003c/p\u003e\\n\u003cp\u003eRamachanran Kadannappalli\u003c/p\u003e\\n\u003cp\u003eMinister for Registration, Museum, Archaeology and Archives\u003c/p\u003e\",\"date\":null},{\"_id\":\"6817090e646ea90521b9b2cd\",\"menuName\":\"Testimonials\",\"title\":\"Ms. Swathi Pavithran\",\"shortDesc\":\"Cincinnati Children's Hospital Medical Center,  Ohio, USA\",\"excerpt\":\"I am Swathi Pavithran, currently pursuing my graduate studies at Cincinnati Children's Hospital Medical Center (CCHMC) in Ohio, USA. My academic journey began at Sir Syed Institute For Technical Studies, where I earned ...\",\"images\":[{\"fileCaption\":\"Ms. Swathi Pavithran\",\"filePath\":\"uploads/WhatsApp Image 2025-04-09 at 10.56.35 PM-2025-05-04-06-30-47.528.jpeg\"}],\"files\":[],\"links\":[],\"description\":\"$18\",\"date\":null,\"order\":2},{\"_id\":\"68170968646ea90521b9b2d1\",\"menuName\":\"Testimonials\",\"title\":\"Mrs. Munavira Mukkoth\",\"shortDesc\":\"MRes  Schhol of Applied Sciences  University of the West of England Bristol, U.K\",\"excerpt\":\"I am Munavira Mukkoth, and I completed my M.Sc in Biotechnology from Sir Syed Institute during the 2020-2022 academic year. As an alumnus of the M.Sc Biotechnology program at Sir Syed Institute, I can confidently say ...\",\"images\":[{\"fileCaption\":\"Ms. Munavira M\",\"filePath\":\"uploads/IMG-20241031-WA0039-2025-05-04-11-37-46.504.jpg\"}],\"files\":[],\"links\":[],\"description\":\"$19\",\"date\":null,\"order\":3},{\"_id\":\"6811e1d6646ea90521b805a5\",\"menuName\":\"Testimonials\",\"title\":\"Ms. Anjana Vijayan\",\"shortDesc\":\"Research Fellow, CCMB, Hyderabad\",\"excerpt\":\"I Anjana Vijayan currently I am a research scholar at CSIR-CCMB Hyderabad. I am truly grateful for the invaluable support I received during my time at SSITS The faculty, especially the Head of Biotechnology department ...\",\"images\":[{\"fileCaption\":\"Ms. ANJANA VIJAYAN\",\"filePath\":\"uploads/IMG-20241108-WA0008-2025-04-30-08-59-37.699.jpg\"}],\"files\":[],\"links\":[],\"description\":\"$1a\",\"date\":null,\"order\":4},{\"_id\":\"6610355f4c84666af3f38370\",\"menuName\":\"Testimonials\",\"title\":\"Mr. Tanveer  \",\"shortDesc\":\"BBM-1st batch\",\"excerpt\":\"Looking back on my journey at SSITS, I can't help but feel immense gratitude for the profound impact it has had on my life. From the moment I stepped onto campus, I knew I had found my second home. The professors' ...\",\"images\":[{\"fileCaption\":\"tanveer\",\"filePath\":\"uploads/tanveer-2024-09-30-12-37-58.951.jpeg\"}],\"files\":[],\"links\":[],\"description\":\"\u003cp\u003eLooking back on my journey at SSITS, I can't help but feel immense gratitude for the profound impact it has had on my life. From the moment I stepped onto campus, I knew I had found my second home. The professors' passion for teaching and mentorship, coupled with the vibrant community and countless opportunities for growth, made every day an adventure. I'm incredibly thankful for the friendships I've formed and the skills I've developed during my time here. Without a doubt, I wholeheartedly recommend SSITS to anyone seeking not just an education, but an unforgettable experience that will shape their future in the most extraordinary ways\u003c/p\u003e\",\"date\":null,\"order\":5},{\"_id\":\"683024cc22d8d5e6096c699e\",\"menuName\":\"Testimonials\",\"title\":\"Mrs. Ramya Raghunathan P K\",\"shortDesc\":\"Assistant Professor\",\"excerpt\":\"Studying at Sir Syed Institute for Technical Studies was a life-changing experience for me. I completed both my B.Sc and M.Sc in Computer Science here, and the journey was nothing short of inspiring. The faculty members ...\",\"images\":[{\"fileCaption\":\"r\",\"filePath\":\"uploads/ramya pic-2025-05-23-07-35-03.253.jfif\"}],\"files\":[],\"links\":[],\"description\":\"\u003cp\u003eStudying at Sir Syed Institute for Technical Studies was a life-changing experience for me. I completed both my B.Sc and M.Sc in Computer Science here, and the journey was nothing short of inspiring. The faculty members were incredibly supportive and knowledgeable\u0026mdash;they played a major role in shaping my academic and professional path. Their guidance made my way clear and achievable. Today, I\u0026rsquo;m proud to be working at the same institution as an Assistant Professor, giving back to the place that helped me grow. It\u0026rsquo;s truly an honor to be part of this esteemed institute.\u003c/p\u003e\",\"date\":null,\"order\":6}]}]]}]}],[\"$\",\"div\",null,{\"className\":\"col-lg-3 mb--60 p-md-5\",\"children\":[\"$\",\"div\",null,{\"className\":\"section-title text-center\",\"children\":[\"$\",\"$L1b\",null,{\"data\":[{\"_id\":\"681ca12a646ea90521bb4f57\",\"menuName\":\"Annual bulletin\",\"title\":\"Publication\",\"date\":\"2025-03-10T18:30:00.000Z\",\"images\":[{\"fileCaption\":\"Publication\",\"filePath\":\"uploads/Cover-2025-10-31-16-23-41.580.jpg\"}],\"files\":[{\"fileCaption\":\"PRISM-Newsletter 2025 \",\"fileDate\":\"2025-03-10T18:30:00.000Z\",\"filePath\":\"uploads/News Letter 2025 PRISM Final-2025-10-31-16-25-39.458.pdf\"}],\"links\":[]}],\"height\":310}]}]}]]}]}]}]}]]\n"])</script><script id="_next-ga-init" data-nscript="afterInteractive">
